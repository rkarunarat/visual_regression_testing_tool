# Visual Regression Testing Tool - Environment Configuration
# Copy this file to .env and modify as needed

# Port Configuration
# External port for the application (default: 80)
EXTERNAL_PORT=80

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=127.0.0.1
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_ENABLE_CORS=false
# Enable XSRF protection in production deployments exposed to a network
STREAMLIT_SERVER_ENABLE_XSRF_PROTECTION=true

# Docker Configuration
DOCKER_IMAGE=visual-regression-testing:latest

# Production Configuration (uncomment for production)
# DOMAIN=your-domain.com
# SSL_EMAIL=your-email@example.com

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Test Configuration
DEFAULT_BROWSER=Chrome
DEFAULT_DEVICE=Desktop
DEFAULT_TIMEOUT=30

# Security (for production)
# APP_PASSWORD: Set a strong password to gate access when the app is exposed on a network.
# Leave unset for local development (auth is skipped when empty).
# APP_PASSWORD=your-strong-password-here
#
# IGNORE_HTTPS_ERRORS: Allow Playwright to load pages with invalid/self-signed TLS certs.
# Default is true (useful for staging environments). Set to false in strict production checks.
# IGNORE_HTTPS_ERRORS=true
#
# Browser / Cloudflare (Playwright)
# PLAYWRIGHT_USE_SYSTEM_BROWSER=true   # Use installed Chrome/Edge (recommended vs bundled Chromium)
# PLAYWRIGHT_HEADLESS=true             # Set false to show browser window (stricter CF sites)
# CLOUDFLARE_WAIT_SECONDS=20           # Max wait for Cloudflare challenge to resolve
# PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=45000
#
# GitHub Actions (manual workflow_dispatch)
# WORKFLOW_RUN_PASSWORD (preferred) or workflow_run_password: password required to start a manual run.
# STAGING_URL / PRODUCTION_URL: Optional URL secrets when ci/config.json is not committed.
#
# SECRET_KEY=your-secret-key-here
# ALLOWED_HOSTS=your-domain.com,www.your-domain.com
